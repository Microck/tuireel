{
  "$schema": "../../src/config/schema.json",
  "output": "smoke-output.mp4",
  "format": "mp4",
  "fps": 10,
  "cols": 40,
  "rows": 12,
  "steps": [
    { "type": "launch", "command": "echo 'Tuireel smoke test'" },
