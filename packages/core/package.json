{
  "name": "@tuireel/core",
  "version": "0.1.0",
  "description": "Core Tuireel recording, compositing, and workflow engine.",
  "keywords": [
    "tuireel",
    "terminal",
    "tui",
    "video",
    "recording"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Microck/tuireel.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^14.0.2",
    "ghostty-opentui": "^1.4.5",
    "jsonc-parser": "^3.3.1",
    "sharp": "^0.34.5",
    "tuistory": "^0.0.16",
    "zod": "^4.1.12",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0"
  }
}
