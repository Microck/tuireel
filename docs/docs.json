{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Tuireel",
  "colors": {
    "primary": "#18AAA7",
    "light": "#18AAA7",
    "dark": "#C1263B"
  },
  "background": {
    "color": {
      "light": "#F5ECD9",
      "dark": "#141015"
    }
  },
  "favicon": {
    "light": "/images/favicon.svg",
    "dark": "/images/favicon.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Configuration",
            "pages": ["config-reference", "steps-reference", "cli-reference"]
          },
          {
            "group": "Features",
            "pages": ["themes", "presets", "sound", "multi-video"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/Microck/tuireel",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/Microck/tuireel"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Microck/tuireel"
    }
  }
}
